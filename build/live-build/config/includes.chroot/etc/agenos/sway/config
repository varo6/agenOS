set $mod Mod4

xwayland enable
default_border none
default_floating_border none
focus_follows_mouse no
mouse_warping none
workspace_auto_back_and_forth no

output * bg #14100d solid_color

workspace 1:home

for_window [workspace="2:app"] fullscreen enable
for_window [app_id="chromium"] move to workspace "1:home"
for_window [class="^Chromium$"] move to workspace "1:home"

bindsym Ctrl+Alt+Return exec python3 /usr/local/bin/agenos-shell-helper terminal
bindsym Ctrl+Alt+r exec python3 /usr/local/bin/agenos-shell-helper reload-shell

exec_always --no-startup-id sh /usr/local/bin/agenos-shell-runner
