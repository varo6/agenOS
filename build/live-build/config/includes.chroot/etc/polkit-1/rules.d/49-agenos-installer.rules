polkit.addRule(function(action, subject) {
    if (action.id !== "com.agenos.installer.run-helper") {
        return polkit.Result.NOT_HANDLED;
    }

    if (subject.local && subject.active && subject.user === "agenos") {
        return polkit.Result.YES;
    }

    return polkit.Result.NOT_HANDLED;
});
