#!/usr/bin/env python3
import argparse
import json
import os
import pwd
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, "/usr/local/lib/agenos-installer")

from common import validate_profile

EXEC_SEQUENCE = [
    "partition",
    "mount",
    "unpackfs",
    "dpkg-unsafe-io",
    "sources-media",
    "machineid",
    "fstab",
    "locale",
    "keyboard",
    "localecfg",
    "users",
    "displaymanager",
    "networkcfg",
    "hwclock",
    "services-systemd",
    "agenosdesktop",
    "bootloader-config",
    "grubcfg",
    "bootloader",
    "packages",
    "luksbootkeyfile",
    "plymouthcfg",
    "initramfscfg",
    "initramfs",
    "dpkg-unsafe-io-undo",
    "sources-media-unmount",
    "sources-final",
    "umount",
]


def original_uid() -> int:
    value = os.environ.get("PKEXEC_UID")
    return int(value) if value else 0


def original_user() -> pwd.struct_passwd:
    return pwd.getpwuid(original_uid())


def original_runtime_dir() -> Path:
    return Path(f"/run/user/{original_uid()}")


def allowed_runtime_dir() -> Path:
    return Path(f"/run/user/{original_uid()}/agenos-installer")


def validate_profile_path(path: str) -> Path:
    candidate = Path(path).resolve()
    runtime_dir = allowed_runtime_dir().resolve()
    if runtime_dir not in candidate.parents:
        raise SystemExit("La ruta del perfil no está dentro de /run/user/<uid>/agenos-installer/")
    return candidate


def load_profile(path: Path) -> dict:
    payload = json.loads(path.read_text(encoding="utf-8"))
    normalized, errors = validate_profile(
        {
            **payload,
            "user": {
                **payload["user"],
                "passwordConfirmation": payload["user"]["password"],
            },
        }
    )
    if errors or normalized is None:
        raise SystemExit(f"Perfil inválido: {errors}")
    return normalized


def create_guided_config(profile_path: Path) -> Path:
    temp_root = Path(tempfile.mkdtemp(prefix="agenos-calamares-"))
    config_dir = temp_root / "calamares"
    shutil.copytree("/etc/calamares", config_dir)
    (config_dir / "modules").mkdir(parents=True, exist_ok=True)
    os.symlink("/usr/share/calamares/qml", config_dir / "qml", target_is_directory=True)

    settings = [
        "---",
        "modules-search:",
        "  - local",
        "  - /usr/lib/calamares/modules",
        "",
        "oem-setup: false",
        "disable-cancel: false",
        "disable-cancel-during-exec: false",
        "quit-at-end: false",
        "",
        "sequence:",
        "  - exec:",
        "      - agenosseed",
        "  - show:",
        "      - partition",
        "      - summary",
        "  - exec:",
        *[f"      - {module}" for module in EXEC_SEQUENCE],
        "  - show:",
        "      - finished",
        "",
        "branding: agenos",
        "prompt-install: false",
        "dont-chroot: false",
        "",
    ]
    (config_dir / "settings.conf").write_text("\n".join(settings), encoding="utf-8")
    (config_dir / "modules" / "agenosseed.conf").write_text(
        "\n".join(
            [
                "---",
                f"profilePath: {json.dumps(str(profile_path))}",
                "",
            ]
        ),
        encoding="utf-8",
    )
    return config_dir


def move_stale_fstab() -> bool:
    current = Path("/etc/fstab")
    backup = Path("/etc/fstab.orig.calamares")
    if current.exists():
        current.rename(backup)
        return True
    return False


def restore_stale_fstab(moved: bool) -> None:
    if moved:
        backup = Path("/etc/fstab.orig.calamares")
        if backup.exists():
            backup.rename(Path("/etc/fstab"))


def allow_root_x11() -> None:
    display = os.environ.get("DISPLAY", "")
    if not display:
        return
    subprocess.run(["xhost", "+si:localuser:root"], check=False)


def revoke_root_x11() -> None:
    display = os.environ.get("DISPLAY", "")
    if not display:
        return
    subprocess.run(["xhost", "-si:localuser:root"], check=False)


def ensure_root_runtime_dir() -> Path:
    runtime_dir = Path(f"/run/user/{os.getuid()}")
    runtime_dir.mkdir(mode=0o700, parents=True, exist_ok=True)
    os.chmod(runtime_dir, 0o700)
    return runtime_dir


def detect_wayland_socket() -> Path | None:
    runtime_dir = original_runtime_dir()
    candidates: list[Path] = []

    configured = os.environ.get("WAYLAND_DISPLAY", "").strip()
    if configured:
        candidates.append(Path(configured) if "/" in configured else runtime_dir / configured)

    candidates.extend(sorted(runtime_dir.glob("wayland-*")))
    seen: set[str] = set()
    for candidate in candidates:
        key = str(candidate)
        if key in seen:
            continue
        seen.add(key)
        try:
            if candidate.exists() and candidate.is_socket():
                return candidate
        except OSError:
            continue
    return None


def build_gui_env() -> dict[str, str]:
    env = os.environ.copy()
    env["QT_AUTO_SCREEN_SCALE_FACTOR"] = "1"
    env.setdefault("LANG", "C.UTF-8")
    env.setdefault("PATH", "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin")
    env.setdefault("XDG_CURRENT_DESKTOP", "AgenOS")
    env.setdefault("XDG_SESSION_DESKTOP", "agenos")

    user = original_user()
    runtime_dir = original_runtime_dir()
    bus_path = runtime_dir / "bus"
    if not env.get("DBUS_SESSION_BUS_ADDRESS") and bus_path.exists():
        env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={bus_path}"

    wayland_socket = detect_wayland_socket()
    if wayland_socket is not None:
        env["WAYLAND_DISPLAY"] = str(wayland_socket)
        env["XDG_SESSION_TYPE"] = "wayland"
        env["XDG_RUNTIME_DIR"] = str(ensure_root_runtime_dir())
        env.setdefault("QT_QPA_PLATFORM", "wayland;xcb")
        return env

    if env.get("DISPLAY"):
        env.setdefault("XDG_SESSION_TYPE", "x11")
        env.setdefault("QT_QPA_PLATFORM", "xcb")
        if not env.get("XAUTHORITY"):
            candidate = Path(user.pw_dir) / ".Xauthority"
            if candidate.exists():
                env["XAUTHORITY"] = str(candidate)

    return env


def run_calamares(command: list[str]) -> int:
    env = build_gui_env()
    summary = {
        key: env.get(key, "")
        for key in (
            "DISPLAY",
            "XAUTHORITY",
            "WAYLAND_DISPLAY",
            "XDG_RUNTIME_DIR",
            "XDG_SESSION_TYPE",
            "DBUS_SESSION_BUS_ADDRESS",
            "QT_QPA_PLATFORM",
        )
    }
    print(f"[agenos-installer-helper] gui env: {json.dumps(summary, ensure_ascii=True)}", flush=True)
    print(f"[agenos-installer-helper] launching: {' '.join(command)}", flush=True)
    return subprocess.call(command, env=env)


def guided(profile_arg: str) -> int:
    profile_path = validate_profile_path(profile_arg)
    load_profile(profile_path)
    config_dir = create_guided_config(profile_path)
    moved_fstab = move_stale_fstab()
    try:
        allow_root_x11()
        return run_calamares(["/usr/bin/calamares", "-c", str(config_dir)])
    finally:
        revoke_root_x11()
        restore_stale_fstab(moved_fstab)
        profile_path.unlink(missing_ok=True)
        shutil.rmtree(config_dir.parent, ignore_errors=True)


def classic() -> int:
    moved_fstab = move_stale_fstab()
    try:
        allow_root_x11()
        return run_calamares(["/usr/bin/calamares"])
    finally:
        revoke_root_x11()
        restore_stale_fstab(moved_fstab)


def main() -> None:
    parser = argparse.ArgumentParser()
    subparsers = parser.add_subparsers(dest="command", required=True)

    guided_parser = subparsers.add_parser("guided")
    guided_parser.add_argument("--profile", required=True)
    subparsers.add_parser("classic")

    args = parser.parse_args()
    if args.command == "guided":
        raise SystemExit(guided(args.profile))
    if args.command == "classic":
        raise SystemExit(classic())
    raise SystemExit(2)


if __name__ == "__main__":
    main()
