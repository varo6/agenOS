{
  "name": "agenos-installer-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck:view": "tsc --noEmit -p tsconfig.json",
    "typecheck:bun": "tsc --noEmit -p tsconfig.node.json",
    "typecheck": "bun run typecheck:view && bun run typecheck:bun",
    "build:view": "vite build",
    "build:api": "mkdir -p build/api && bun build --target=bun ./src/bun/server.ts --outfile build/api/server.js && bun build --target=bun ./src/bun/cli.ts --outfile build/api/cli.js",
    "build": "bun run typecheck && bun run build:api && bun run build:view",
    "dev": "bun run dev:stack",
    "dev:stack": "bun run src/bun/dev.ts",
    "dev:view": "vite",
    "dev:api": "bun run src/bun/server.ts",
    "preview": "vite preview",
    "test:bun": "bun test src/bun",
    "test:renderer": "vitest run",
    "test": "bun run test:bun && bun run test:renderer"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.8",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.4.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
