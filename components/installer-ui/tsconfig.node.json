{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "types": ["node", "bun"],
    "skipLibCheck": true
  },
  "include": [
    "src/bun/**/*.ts",
    "src/shared/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
