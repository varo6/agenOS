{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgenOS Installer",
  "version": "0.1.0",
  "identifier": "com.agenos.installer",
  "build": {
    "beforeDevCommand": "bun run dev:stack",
    "beforeBuildCommand": "bun run build:view",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false
  }
}
